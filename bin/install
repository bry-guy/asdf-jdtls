#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=../lib/utils.bash
source "${plugin_dir}/lib/utils.bash"

if [ "$ASDF_INSTALL_TYPE" != "version" ]; then
    fail "asdf-jdtls supports release installs only"
fi

resolved_version="$ASDF_INSTALL_VERSION"
if [ -f "${ASDF_DOWNLOAD_PATH}/resolved-version" ]; then
    resolved_version=$(cat "${ASDF_DOWNLOAD_PATH}/resolved-version")
fi

echo "Installing JDTLS release $resolved_version..."

if ! java_check_compatibility "$resolved_version"; then
    min_java=$(jdtls_min_java_for_version "$resolved_version")
    detected_java=$(java_detect_major || true)

    if [[ "$ASDF_INSTALL_VERSION" == latest-compatible || "$ASDF_INSTALL_VERSION" == latest-java* ]]; then
        fail "JDTLS $resolved_version requires Java $min_java+, but detected Java ${detected_java:-unknown}"
    fi

    echo "Warning: JDTLS $resolved_version requires Java $min_java+, but detected Java ${detected_java:-unknown}."
    echo "Warning: The install will complete, but running jdtls may fail until you use a newer JDK."
fi

mkdir -p "$ASDF_INSTALL_PATH"

archive="${ASDF_DOWNLOAD_PATH}/jdtls-${resolved_version}.tar.gz"
tar -xzf "$archive" -C "$ASDF_INSTALL_PATH" || fail "Could not extract $archive"

# Make the jdtls wrapper script executable
mkdir -p "${ASDF_INSTALL_PATH}/bin"
wrapper_path="${plugin_dir}/bin/jdtls"
cp "$wrapper_path" "${ASDF_INSTALL_PATH}/bin/jdtls"
chmod +x "${ASDF_INSTALL_PATH}/bin/jdtls"

# Patch the bundled Gradle Tooling API if it's too old for modern Java/Gradle
# shellcheck source=../lib/patch-tooling-api.bash
source "${plugin_dir}/lib/patch-tooling-api.bash"
patch_tooling_api "$ASDF_INSTALL_PATH"

# Clean up download directory
rm -rf "$ASDF_DOWNLOAD_PATH"

echo "JDTLS $resolved_version installation complete!"
