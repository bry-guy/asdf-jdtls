#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=../lib/utils.bash
source "${plugin_dir}/lib/utils.bash"
mkdir -p "$ASDF_DOWNLOAD_PATH"

resolved_version=$(jdtls_resolve_version "$ASDF_INSTALL_VERSION")
url=$(jdtls_release_dir_url "$resolved_version")

echo "Requested JDTLS version: $ASDF_INSTALL_VERSION"
echo "Resolved JDTLS version: $resolved_version"

filename=$(jdtls_find_archive_name "$resolved_version")

if [ -z "$filename" ]; then
  fail "Could not find release archive for JDTLS version $resolved_version"
fi

echo "Found JDTLS release archive: $filename"
printf '%s\n' "$resolved_version" >"${ASDF_DOWNLOAD_PATH}/resolved-version"

web_download_and_verify_sha256 "${url}${filename}" "${ASDF_DOWNLOAD_PATH}/jdtls-${resolved_version}.tar.gz"
